<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <corners android:radius="14dp" />
            <gradient
                android:angle="45"
                android:startColor="#13263F"
                android:endColor="#0D1A2E" />
            <stroke
                android:width="1dp"
                android:color="#3D6798" />
        </shape>
    </item>
    <item android:top="16dp" android:left="16dp" android:right="16dp" android:bottom="16dp">
        <shape>
            <corners android:radius="10dp" />
            <gradient
                android:angle="0"
                android:startColor="#0D1727"
                android:endColor="#101E32" />
            <stroke
                android:width="1dp"
                android:color="#35577F" />
        </shape>
    </item>
</layer-list>
