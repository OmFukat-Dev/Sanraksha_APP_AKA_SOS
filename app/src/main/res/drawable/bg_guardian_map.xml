<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <corners android:radius="14dp" />
            <gradient
                android:angle="45"
                android:startColor="#DDEEFF"
                android:endColor="#C9E1F7" />
            <stroke
                android:width="1dp"
                android:color="#94B9DE" />
        </shape>
    </item>
    <item android:top="16dp" android:left="16dp" android:right="16dp" android:bottom="16dp">
        <shape>
            <corners android:radius="10dp" />
            <gradient
                android:angle="0"
                android:startColor="#F3FAFF"
                android:endColor="#DDEEFF" />
            <stroke
                android:width="1dp"
                android:color="#98BEE2" />
        </shape>
    </item>
</layer-list>
